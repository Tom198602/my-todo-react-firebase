rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidTask(data) {
      return data.keys().hasOnly(["title", "done", "createdAt", "updatedAt"])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.done is bool
        && data.createdAt is number
        && data.updatedAt is number;
    }

    match /users/{userId}/tasks/{taskId} {
      allow read, delete: if signedInAs(userId);
      allow create, update: if signedInAs(userId)
        && isValidTask(request.resource.data);
    }
  }
}
